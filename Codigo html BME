<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>BME680 Futuristic Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">

<style>

:root{
  --bg:#050816;
  --panel:#0f172acc;
  --border:#1e3a5f;
  --text:#e2f3ff;
  --cyan:#00e5ff;
  --blue:#3b82f6;
  --purple:#b026ff;
  --orange:#ff6a00;
  --green:#00ffae;
  --yellow:#ffd000;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{

  min-height:100vh;

  font-family:'Rajdhani',sans-serif;

  color:var(--text);

  background:
  radial-gradient(circle at top left,#102040 0%,transparent 25%),
  radial-gradient(circle at bottom right,#22003d 0%,transparent 25%),
  linear-gradient(135deg,#020617 0%,#050816 50%,#030712 100%);

  overflow-x:hidden;

  padding:25px;

  position:relative;
}

/* GRID FONDO */

body::before{

  content:"";

  position:fixed;

  inset:0;

  background-image:
  linear-gradient(rgba(0,255,255,0.04) 1px, transparent 1px),
  linear-gradient(90deg, rgba(0,255,255,0.04) 1px, transparent 1px);

  background-size:40px 40px;

  pointer-events:none;
}

/* HEADER */

header{

  text-align:center;

  margin-bottom:40px;
}

header h1{

  font-family:'Orbitron',sans-serif;

  font-size:55px;

  font-weight:800;

  letter-spacing:6px;

  color:#fff;

  text-shadow:
  0 0 10px var(--cyan),
  0 0 20px var(--cyan),
  0 0 40px var(--cyan);
}

header p{

  margin-top:12px;

  color:#8fb8d8;

  letter-spacing:4px;

  font-size:15px;
}

/* GRID */

.grid{

  display:grid;

  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

  gap:25px;

  max-width:1700px;

  margin:auto;
}

/* TARJETAS */

.card{

  position:relative;

  background:rgba(15,23,42,0.72);

  border:1px solid #1e3a5f;

  border-radius:25px;

  padding:28px;

  overflow:hidden;

  backdrop-filter:blur(14px);

  transition:0.4s;

  min-height:280px;

  display:flex;

  flex-direction:column;

  justify-content:space-between;

  box-shadow:
  inset 0 0 25px rgba(255,255,255,0.03),
  0 0 20px rgba(0,0,0,0.4);
}

.card:hover{

  transform:translateY(-8px) scale(1.02);

  box-shadow:
  0 0 25px rgba(0,255,255,0.2),
  0 0 60px rgba(0,255,255,0.08);
}

/* BORDES */

.card::before{

  content:"";

  position:absolute;

  inset:0;

  padding:2px;

  border-radius:25px;

  -webkit-mask:
  linear-gradient(#fff 0 0) content-box,
  linear-gradient(#fff 0 0);

  -webkit-mask-composite:xor;

  mask-composite:exclude;
}

.temp::before{
  background:linear-gradient(135deg,#ff4d4d,#ff9900);
}

.hum::before{
  background:linear-gradient(135deg,#00aaff,#00e5ff);
}

.pres::before{
  background:linear-gradient(135deg,#7c3aed,#d946ef);
}

.alt::before{
  background:linear-gradient(135deg,#00e5ff,#00ffae);
}

.gas::before{
  background:linear-gradient(135deg,#ffae00,#ffd000);
}

/* TITULO */

.card-title{

  font-size:22px;

  font-weight:600;

  letter-spacing:2px;

  margin-bottom:15px;
}

/* NUMEROS */

.value{

  font-family:'Orbitron',sans-serif;

  font-size:48px;

  font-weight:800;

  text-shadow:0 0 20px rgba(255,255,255,0.25);

  line-height:1.1;

  white-space:nowrap;

  overflow:hidden;
}

/* ALTITUD */

#altitude{

  font-size:48px;
}

/* UNIDADES */

.unit{

  font-size:18px;

  opacity:0.8;
}

/* LINEAS */

.wave{

  width:100%;

  height:60px;

  margin-top:15px;

  opacity:0.7;
}

/* FOOTER */

.footer{

  max-width:1700px;

  margin:35px auto 0;

  background:rgba(15,23,42,0.7);

  border:1px solid #1e3a5f;

  border-radius:20px;

  padding:20px;

  display:flex;

  justify-content:space-between;

  flex-wrap:wrap;

  gap:15px;

  backdrop-filter:blur(12px);
}

.footer-box{

  display:flex;

  align-items:center;

  gap:10px;

  font-size:18px;
}

.online{

  color:#00ff88;

  text-shadow:0 0 10px #00ff88;
}

.dot{

  width:12px;

  height:12px;

  border-radius:50%;

  background:#00ff88;

  box-shadow:0 0 12px #00ff88;

  animation:pulse 2s infinite;
}

@keyframes pulse{

  0%,100%{
    opacity:1;
  }

  50%{
    opacity:0.3;
  }
}

</style>
</head>

<body>

<header>

  <h1>BME680</h1>

  <p>SENSOR DASHBOARD · DATOS EN TIEMPO REAL</p>

</header>

<div class="grid">

  <!-- TEMPERATURA -->

  <div class="card temp">

    <div class="card-title">🌡 TEMPERATURA</div>

    <div class="value">
      <span id="temperature">--</span>
      <span class="unit">°C</span>
    </div>

    <svg class="wave" viewBox="0 0 500 100">
      <path d="M0 60 Q50 20 100 60 T200 60 T300 60 T400 60 T500 60"
      stroke="#ff6a00"
      stroke-width="4"
      fill="none"/>
    </svg>

  </div>

  <!-- HUMEDAD -->

  <div class="card hum">

    <div class="card-title">💧 HUMEDAD</div>

    <div class="value">
      <span id="humidity">--</span>
      <span class="unit">%</span>
    </div>

    <svg class="wave" viewBox="0 0 500 100">
      <path d="M0 60 Q50 20 100 60 T200 60 T300 60 T400 60 T500 60"
      stroke="#00e5ff"
      stroke-width="4"
      fill="none"/>
    </svg>

  </div>

  <!-- PRESION -->

  <div class="card pres">

    <div class="card-title">⛰ PRESIÓN</div>

    <div class="value">
      <span id="pressure">--</span>
      <span class="unit">hPa</span>
    </div>

    <svg class="wave" viewBox="0 0 500 100">
      <path d="M0 60 Q50 20 100 60 T200 60 T300 60 T400 60 T500 60"
      stroke="#d946ef"
      stroke-width="4"
      fill="none"/>
    </svg>

  </div>

  <!-- ALTITUD -->

  <div class="card alt">

    <div class="card-title">🛰 ALTITUD</div>

    <div class="value">
      <span id="altitude">--</span>
      <span class="unit">m</span>
    </div>

    <svg class="wave" viewBox="0 0 500 100">
      <path d="M0 60 Q50 20 100 60 T200 60 T300 60 T400 60 T500 60"
      stroke="#00ffae"
      stroke-width="4"
      fill="none"/>
    </svg>

  </div>

  <!-- GAS -->

  <div class="card gas">

    <div class="card-title">🔥 GAS VOC</div>

    <div class="value">
      <span id="gas">--</span>
      <span class="unit">kΩ</span>
    </div>

    <svg class="wave" viewBox="0 0 500 100">
      <path d="M0 60 Q50 20 100 60 T200 60 T300 60 T400 60 T500 60"
      stroke="#ffd000"
      stroke-width="4"
      fill="none"/>
    </svg>

  </div>

</div>

<div class="footer">

  <div class="footer-box">

    <div class="dot"></div>

    <span id="status" class="online">
      SISTEMA ONLINE
    </span>

  </div>

  <div class="footer-box">

    Última actualización:

    <span id="time"></span>

  </div>

</div>

<script>

/* ========= TOKEN ========= */

const TOKEN = "43aae551-90e8-495c-b56b-8725fbf3a80f";

/* ========= GET VARIABLE ========= */

async function getVariable(variable){

  const url =
  `https://api.tago.io/data?variable=${variable}&qty=1`;

  const response = await fetch(url,{

    method:"GET",

    headers:{
      "Device-Token": TOKEN
    }
  });

  if(!response.ok){

    throw new Error("HTTP " + response.status);
  }

  const data = await response.json();

  if(data.result && data.result.length > 0){

    return parseFloat(data.result[0].value);
  }

  return null;
}

/* ========= UPDATE ========= */

async function updateData(){

  try{

    const temp =
    await getVariable("temperature");

    const hum =
    await getVariable("humidity");

    const pres =
    await getVariable("pressure");

    const alt =
    await getVariable("altitude");

    const gas =
    await getVariable("gas_resistance");

    if(temp !== null)
      document.getElementById("temperature")
      .innerHTML = temp.toFixed(1);

    if(hum !== null)
      document.getElementById("humidity")
      .innerHTML = hum.toFixed(1);

    if(pres !== null)
      document.getElementById("pressure")
      .innerHTML = pres.toFixed(1);

    if(alt !== null)
      document.getElementById("altitude")
      .innerHTML = alt.toFixed(1);

    if(gas !== null)
      document.getElementById("gas")
      .innerHTML = (gas/1000).toFixed(1);

    document.getElementById("time")
    .innerHTML =
    new Date().toLocaleTimeString("es-EC");

  }

  catch(error){

    console.error(error);

    document.getElementById("status")
    .innerHTML = "ERROR";
  }
}

updateData();

setInterval(updateData,5000);

</script>

</body>
</html>
