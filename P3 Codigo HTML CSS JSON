<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Panel Distancia TagoIO</title>

<style>
body {
    margin: 0;
    background: #0d1117;
    font-family: Arial;
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

/* TARJETA */
.card {
    background: #161b22;
    padding: 25px;
    border-radius: 15px;
    width: 300px;
    text-align: center;
    box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

/* VALOR */
.value {
    font-size: 3em;
    margin: 10px 0;
}

/* BARRA */
.progress {
    height: 10px;
    background: #333;
    border-radius: 10px;
    overflow: hidden;
}

.fill {
    height: 100%;
    width: 0%;
    transition: 0.5s;
}

/* ESTADOS */
.safe { background: #00c853; }
.warning { background: #ffab00; }
.danger { background: #d50000; }

.status {
    margin-top: 10px;
}
</style>
</head>

<body>

<div class="card">
    <h3>Distancia Sensor</h3>
    <div id="value" class="value">---</div>

    <div class="progress">
        <div id="bar" class="fill"></div>
    </div>

    <div id="status" class="status">CONECTANDO...</div>
</div>

<script>

// 🔑 PON TU TOKEN AQUÍ
const TOKEN = "5c6a0971-a300-4ce7-81d1-fe782733f082";

// 📡 OBTENER DATOS DE TAGOIO
async function obtenerDatos() {
    try {
        const res = await fetch("https://api.tago.io/data?variable=distancia&qty=1", {
            method: "GET",
            headers: {
                "Device-Token": TOKEN
            }
        });

        const data = await res.json();

        // Validar JSON
        if (data.result && data.result.length > 0) {

            const json = {
                distancia: parseFloat(data.result[0].value)
            };

            updateUI(json);
        }

    } catch (error) {
        console.log("Error:", error);
    }
}

// 🔄 ACTUALIZA CADA 3 SEGUNDOS
setInterval(obtenerDatos, 3000);

// 🎨 ACTUALIZAR INTERFAZ
function updateUI(data) {
    const valor = data.distancia;

    const value = document.getElementById("value");
    const bar = document.getElementById("bar");
    const status = document.getElementById("status");

    value.innerText = valor.toFixed(1) + " cm";

    let porcentaje = Math.min(valor, 100);
    bar.style.width = porcentaje + "%";

    bar.className = "fill";

    if (valor < 15) {
        bar.classList.add("danger");
        status.innerText = "PELIGRO";
    } 
    else if (valor < 40) {
        bar.classList.add("warning");
        status.innerText = "CUIDADO";
    } 
    else {
        bar.classList.add("safe");
        status.innerText = "SEGURO";
    }
}

</script>

</body>
</html>
