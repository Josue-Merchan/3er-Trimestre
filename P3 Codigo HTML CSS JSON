<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TagoIO HUD Distancia</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');

:root {
    --theme-color: #00f3ff;
    --theme-glow: rgba(0, 243, 255, 0.5);
    --theme-bg: rgba(0, 243, 255, 0.05);
}

body {
    font-family: 'Share Tech Mono', monospace;
    margin: 0;
    padding: 0;
    background: linear-gradient(180deg, #001f4d, #8b0000); /* azul a rojo */
    color: var(--theme-color);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.hud-container {
    background: #0a0a12;
    padding: 20px;
    border-radius: 10px;
    border: 2px solid var(--theme-color);
    box-shadow: 0 0 15px var(--theme-glow);
    width: 90%;
    max-width: 350px;
    text-align: center;
    position: relative;
}

.header {
    font-size: 0.8em;
    margin-bottom: 10px;
}

.value {
    font-size: 4em;
}

.bar-container {
    width: 100%;
    height: 12px;
    background: rgba(255,255,255,0.1);
    border: 1px solid var(--theme-color);
}

.bar-fill {
    height: 100%;
    width: 0%;
    background: var(--theme-color);
}

.status-msg {
    font-size: 0.75em;
    margin-top: 5px;
}

/* Emoji */
.emoji {
    font-size: 2.5em;
    position: relative;
    transition: left 0.3s ease;
}

/* Estados */
.mode-safe { --theme-color: #00ffaa; }
.mode-warning { --theme-color: #ffaa00; }
.mode-danger { --theme-color: #ff0044; }

/* Footer */
.footer {
    position: absolute;
    bottom: 10px;
    font-size: 0.7em;
    opacity: 0.7;
}
</style>
</head>

<body>

<div id="hud" class="hud-container mode-safe">

    <div class="header">TAGOIO SENSOR DATA</div>

    <div id="emoji" class="emoji">👑</div>

    <div class="value-box">
        <div id="distance-value" class="value">---</div>
        <div>cm</div>
    </div>

    <div class="bar-container">
        <div id="distance-bar" class="bar-fill"></div>
    </div>

    <div id="status-msg" class="status-msg">CONECTANDO...</div>

</div>

<div class="footer">Jonnathan Carabajo</div>

<script>
const token = "5c6a0971-a300-4ce7-81d1-fe782733f082";

async function obtenerDatos() {
    try {
        const response = await fetch("https://api.tago.io/data?variable=distancia&qty=1", {
            method: "GET",
            headers: {
                "Device-Token": token
            }
        });

        const data = await response.json();

        if (data.result && data.result.length > 0) {
            const valor = parseFloat(data.result[0].value);
            updateUI(valor);
        }

    } catch (error) {
        console.error("Error:", error);
    }
}

setInterval(obtenerDatos, 3000);

function updateUI(valor) {
    const val = document.getElementById('distance-value');
    const bar = document.getElementById('distance-bar');
    const hud = document.getElementById('hud');
    const msg = document.getElementById('status-msg');
    const emoji = document.getElementById('emoji');

    val.innerText = valor.toFixed(1);

    let porcentaje = Math.min(Math.max(valor, 0), 100);
    bar.style.width = (100 - porcentaje) + '%';

    /* Movimiento emoji (0 a 100 cm → izquierda a derecha) */
    emoji.style.left = porcentaje + '%';

    if (valor < 15) {
        hud.className = 'hud-container mode-danger';
        msg.innerText = '¡ALERTA!';
    } else if (valor < 40) {
        hud.className = 'hud-container mode-warning';
        msg.innerText = 'PRECAUCIÓN';
    } else {
        hud.className = 'hud-container mode-safe';
        msg.innerText = 'OK';
    }
}
</script>

</body>
</html>



