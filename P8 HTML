<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>GPS Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{

  min-height:100vh;

  font-family:'Rajdhani',sans-serif;

  color:white;

  padding:25px;

  overflow-x:hidden;

  background:
  radial-gradient(circle at top left,#003566 0%,transparent 30%),
  radial-gradient(circle at bottom right,#3a0066 0%,transparent 30%),
  linear-gradient(135deg,#020617 0%,#030712 50%,#010409 100%);
}

/* GRID */

body::before{

  content:"";

  position:fixed;

  inset:0;

  background-image:
  linear-gradient(rgba(0,255,255,0.05) 1px, transparent 1px),
  linear-gradient(90deg, rgba(0,255,255,0.05) 1px, transparent 1px);

  background-size:40px 40px;

  pointer-events:none;
}

header{

  text-align:center;

  margin-bottom:40px;
}

header h1{

  font-family:'Orbitron',sans-serif;

  font-size:60px;

  letter-spacing:8px;

  text-shadow:
  0 0 15px #00f0ff,
  0 0 35px #00f0ff;
}

header p{

  margin-top:10px;

  letter-spacing:4px;

  color:#8bb6d6;
}

/* GRID */

.grid{

  display:grid;

  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

  gap:25px;

  max-width:1700px;

  margin:auto;
}

/* CARD */

.card{

  background:rgba(8,15,35,0.75);

  border-radius:25px;

  padding:28px;

  backdrop-filter:blur(15px);

  min-height:260px;

  transition:0.4s;

  border:2px solid rgba(255,255,255,0.08);

  box-shadow:
  0 0 20px rgba(0,0,0,0.4),
  inset 0 0 20px rgba(255,255,255,0.03);
}

.card:hover{

  transform:translateY(-8px) scale(1.02);
}

/* COLORES */

.lat{
  border-color:#00e5ff;
  box-shadow:0 0 18px rgba(0,229,255,0.4);
}

.lng{
  border-color:#00ff9d;
  box-shadow:0 0 18px rgba(0,255,157,0.4);
}

.speed{
  border-color:#ff6a00;
  box-shadow:0 0 18px rgba(255,106,0,0.4);
}

.sat{
  border-color:#c026ff;
  box-shadow:0 0 18px rgba(192,38,255,0.4);
}

.alt{
  border-color:#ffd500;
  box-shadow:0 0 18px rgba(255,213,0,0.4);
}

.date{
  border-color:#4d7cff;
  box-shadow:0 0 18px rgba(77,124,255,0.4);
}

.time{
  border-color:#ff4da6;
  box-shadow:0 0 18px rgba(255,77,166,0.4);
}

/* TEXT */

.title{

  font-size:22px;

  margin-bottom:20px;

  letter-spacing:2px;
}

.value{

  font-family:'Orbitron',sans-serif;

  font-size:38px;

  font-weight:800;

  word-break:break-word;

  text-shadow:0 0 15px rgba(255,255,255,0.2);
}

.footer{

  margin-top:35px;

  text-align:center;

  font-size:20px;

  color:#00ff9d;

  text-shadow:0 0 10px #00ff9d;
}

</style>
</head>

<body>

<header>

  <h1>GPS TRACKER</h1>

  <p>REAL TIME SATELLITE MONITOR</p>

</header>

<div class="grid">

  <div class="card lat">
    <div class="title">📍 LATITUD</div>
    <div class="value" id="latitude">--</div>
  </div>

  <div class="card lng">
    <div class="title">🌍 LONGITUD</div>
    <div class="value" id="longitude">--</div>
  </div>

  <div class="card speed">
    <div class="title">🚗 VELOCIDAD</div>
    <div class="value" id="speed">--</div>
  </div>

  <div class="card sat">
    <div class="title">🛰 SATÉLITES</div>
    <div class="value" id="satellites">--</div>
  </div>

  <div class="card alt">
    <div class="title">⛰ ALTITUD GPS</div>
    <div class="value" id="gps_altitude">--</div>
  </div>

  <div class="card date">
    <div class="title">📅 FECHA</div>
    <div class="value" id="gps_date">--</div>
  </div>

  <div class="card time">
    <div class="title">⏰ HORA</div>
    <div class="value" id="gps_time">--</div>
  </div>

</div>

<div class="footer">

  SISTEMA GPS ONLINE

</div>

<script>

const TOKEN = "TU_TOKEN_TAGO";

/* GET VARIABLE */

async function getVariable(variable){

  const response = await fetch(
    `https://api.tago.io/data?variable=${variable}&qty=1`,
    {
      headers:{
        "Device-Token":TOKEN
      }
    }
  );

  const data = await response.json();

  if(data.result && data.result.length > 0){

    return data.result[0].value;
  }

  return "--";
}

/* UPDATE */

async function updateData(){

  document.getElementById("latitude")
  .innerHTML =
  await getVariable("latitude");

  document.getElementById("longitude")
  .innerHTML =
  await getVariable("longitude");

  document.getElementById("speed")
  .innerHTML =
  await getVariable("speed") + " km/h";

  document.getElementById("satellites")
  .innerHTML =
  await getVariable("satellites");

  document.getElementById("gps_altitude")
  .innerHTML =
  await getVariable("gps_altitude") + " m";

  document.getElementById("gps_date")
  .innerHTML =
  await getVariable("gps_date");

  document.getElementById("gps_time")
  .innerHTML =
  await getVariable("gps_time");
}

updateData();

setInterval(updateData,5000);

</script>

</body>
</html>
