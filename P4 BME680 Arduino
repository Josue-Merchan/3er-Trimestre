#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

#define SEALEVELPRESSURE_HPA (1013.25)

Adafruit_BME680 bme; // I2C

void setup() {
  Serial.begin(115200);
  delay(2000);

  Serial.println("Iniciando BME680...");

  // SDA = 21, SCL = 22
  Wire.begin(21, 22);

  // Dirección 0x76 o 0x77
  if (!bme.begin(0x76)) {

    // intenta la otra dirección
    if (!bme.begin(0x77)) {
      Serial.println("No se encontro el sensor BME680");
      while (1);
    }
  }

  // Configuración recomendada
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);

  // Calentador de gas
  bme.setGasHeater(320, 150);

  Serial.println("BME680 iniciado correctamente");
}

void loop() {

  if (!bme.performReading()) {
    Serial.println("Error al leer el sensor");
    return;
  }

  Serial.println("===== DATOS BME680 =====");

  // Temperatura
  Serial.print("Temperatura: ");
  Serial.print(bme.temperature);
  Serial.println(" °C");

  // Humedad
  Serial.print("Humedad: ");
  Serial.print(bme.humidity);
  Serial.println(" %");

  // Presión
  Serial.print("Presion: ");
  Serial.print(bme.pressure / 100.0);
  Serial.println(" hPa");

  // Altitud
  Serial.print("Altitud aprox: ");
  Serial.print(
    bme.readAltitude(SEALEVELPRESSURE_HPA)
  );
  Serial.println(" m");

  // Gas
  Serial.print("Gas VOC: ");
  Serial.print(bme.gas_resistance / 1000.0);
  Serial.println(" KOhms");

  Serial.println("========================");
  Serial.println();

  delay(2000);
}
